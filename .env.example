# ─── Telegram Bot ──────────────────────────────────────────────────────────────
# Получить у @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# ─── ProxyAPI (OpenAI-совместимый, работает в РФ без VPN) ──────────────────────
# Получить на https://proxyapi.ru/
PROXY_API_KEY=your_proxyapi_key_here
PROXY_API_BASE=https://api.proxyapi.ru/openai/v1

# ─── LLM модель ────────────────────────────────────────────────────────────────
# Доступные: gpt-4o-mini, gpt-4o, gpt-4-turbo
LLM_MODEL=gpt-4o-mini

# ─── Память диалога ────────────────────────────────────────────────────────────
# Количество сообщений (user + assistant) хранимых в контексте
MAX_HISTORY_MESSAGES=10

# ─── Генерация видео ───────────────────────────────────────────────────────────
VIDEO_MODEL=sora-2
VIDEO_DURATION=4

# ─── Стоимость токенов (USD за 1M токенов) ────────────────────────────────────
# gpt-4o-mini: 0.15 вход / 0.60 выход
# gpt-4o: 2.50 вход / 10.00 выход
COST_INPUT_PER_1M=0.15
COST_OUTPUT_PER_1M=0.60

# ─── Karing SOCKS5 прокси ──────────────────────────────────────────────────────
# Karing по умолчанию слушает на порту 3067
# Чтобы отключить прокси — оставь значение пустым: SOCKS5_PROXY=
SOCKS5_PROXY=socks5://127.0.0.1:3067

# ─── Karing SOCKS5 прокси ──────────────────────────────────────────────────────
# Локальный запуск (без Docker):
# SOCKS5_PROXY=socks5://127.0.0.1:3067
# Запуск в Docker (docker-compose.yml уже настроен):
SOCKS5_PROXY=socks5://host.docker.internal:3067
